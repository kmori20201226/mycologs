{
  "name": "mycologs",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm --workspace apps/api run dev",
    "build": "npm run build -ws",
    "start": "node apps/api/dist/server.js",
    "db:up": "docker compose -f docker/postgres/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/postgres/docker-compose.yml down",
    "migrate": "bash scripts/migrate.sh",
    "do-migrate": "npx prisma migrate dev",
    "prisma:gen": "npx prisma generate",
    "test:users": "npx ts-node apps/api/test/users.test.ts",
    "test:clubs": "npx ts-node apps/api/test/clubs.test.ts",
    "test:roles": "npx ts-node apps/api/test/roles.test.ts",
    "test:oauth-accounts": "npx ts-node apps/api/test/oauth-accounts.test.ts",
    "test": "npm run test:users && npm run test:clubs && npm run test:roles && npm run test:oauth-accounts"
  },
  "keywords": [],
  "author": "Kazuya Mori",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0"
  }
}
